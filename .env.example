# ==============================================
# APPWRITE ENVIRONMENT VARIABLES FOR COOLIFY
# ==============================================
# Copy this file and configure in Coolify's Environment Variables UI
# Required variables are marked with (REQUIRED)
# ==============================================

# ==============================================
# CORE CONFIGURATION
# ==============================================

# Environment (production, development, staging)
_APP_ENV=production

# Your domain where Appwrite will be accessible (REQUIRED)
# Example: api.yourdomain.com or appwrite.yourdomain.com
_APP_DOMAIN=

# Domain target (usually same as _APP_DOMAIN)
_APP_DOMAIN_TARGET=

# Domain for functions (optional)
_APP_DOMAIN_FUNCTIONS=

# Locale
_APP_LOCALE=en

# ==============================================
# SECURITY (REQUIRED)
# ==============================================

# OpenSSL encryption key - MUST be generated (REQUIRED)
# Generate with: openssl rand -base64 32
_APP_OPENSSL_KEY_V1=

# Executor secret for function execution (REQUIRED)
# Generate with: openssl rand -base64 32
_APP_EXECUTOR_SECRET=

# ==============================================
# DATABASE CONFIGURATION (REQUIRED)
# ==============================================

# Database host (use 'mariadb' for internal service)
_APP_DB_HOST=mariadb

# Database port
_APP_DB_PORT=3306

# Database name (REQUIRED)
_APP_DB_SCHEMA=appwrite

# Database user (REQUIRED)
_APP_DB_USER=appwrite

# Database password (REQUIRED)
# Generate a strong password
_APP_DB_PASS=

# Database root password (REQUIRED)
# Generate a strong password
_APP_DB_ROOT_PASS=

# ==============================================
# REDIS CONFIGURATION
# ==============================================

# Redis host (use 'redis' for internal service)
_APP_REDIS_HOST=redis

# Redis port
_APP_REDIS_PORT=6379

# Redis user (optional)
_APP_REDIS_USER=

# Redis password (optional but recommended)
_APP_REDIS_PASS=

# ==============================================
# STORAGE CONFIGURATION
# ==============================================

# Storage device (local, s3, do-spaces, backblaze, linode, wasabi)
_APP_STORAGE_DEVICE=local

# Maximum file upload size in bytes (default 30MB)
_APP_STORAGE_LIMIT=30000000

# Maximum preview file size in bytes (default 20MB)
_APP_STORAGE_PREVIEW_LIMIT=20000000

# Antivirus scanning (enabled/disabled)
_APP_STORAGE_ANTIVIRUS=disabled
_APP_STORAGE_ANTIVIRUS_HOST=
_APP_STORAGE_ANTIVIRUS_PORT=

# AWS S3 Configuration (if using S3)
_APP_STORAGE_S3_ACCESS_KEY=
_APP_STORAGE_S3_SECRET=
_APP_STORAGE_S3_REGION=
_APP_STORAGE_S3_BUCKET=

# DigitalOcean Spaces Configuration
_APP_STORAGE_DO_SPACES_ACCESS_KEY=
_APP_STORAGE_DO_SPACES_SECRET=
_APP_STORAGE_DO_SPACES_REGION=
_APP_STORAGE_DO_SPACES_BUCKET=

# Backblaze Configuration
_APP_STORAGE_BACKBLAZE_ACCESS_KEY=
_APP_STORAGE_BACKBLAZE_SECRET=
_APP_STORAGE_BACKBLAZE_REGION=
_APP_STORAGE_BACKBLAZE_BUCKET=

# Linode Configuration
_APP_STORAGE_LINODE_ACCESS_KEY=
_APP_STORAGE_LINODE_SECRET=
_APP_STORAGE_LINODE_REGION=
_APP_STORAGE_LINODE_BUCKET=

# Wasabi Configuration
_APP_STORAGE_WASABI_ACCESS_KEY=
_APP_STORAGE_WASABI_SECRET=
_APP_STORAGE_WASABI_REGION=
_APP_STORAGE_WASABI_BUCKET=

# ==============================================
# EMAIL / SMTP CONFIGURATION
# ==============================================

_APP_SMTP_HOST=
_APP_SMTP_PORT=
_APP_SMTP_SECURE=
_APP_SMTP_USERNAME=
_APP_SMTP_PASSWORD=

# ==============================================
# SMS CONFIGURATION
# ==============================================

_APP_SMS_PROVIDER=
_APP_SMS_FROM=

# ==============================================
# FUNCTIONS CONFIGURATION
# ==============================================

# Maximum function size in bytes (default 30MB)
_APP_FUNCTIONS_SIZE_LIMIT=30000000

# Function execution timeout in seconds (default 900 = 15 minutes)
_APP_FUNCTIONS_TIMEOUT=900

# Function build timeout in seconds
_APP_FUNCTIONS_BUILD_TIMEOUT=900

# CPU cores allocated to functions (0 = unlimited)
_APP_FUNCTIONS_CPUS=0

# Memory allocated to functions in MB (0 = unlimited)
_APP_FUNCTIONS_MEMORY=0

# Available runtimes
_APP_FUNCTIONS_RUNTIMES=node-18.0,python-3.9,php-8.0

# Executor host (internal)
_APP_EXECUTOR_HOST=http://openruntimes-executor/v1

# ==============================================
# COMPUTE / DOCKER CONFIGURATION
# ==============================================

# Inactive threshold for function containers (seconds)
_APP_COMPUTE_INACTIVE_THRESHOLD=600

# Maintenance interval (seconds)
_APP_COMPUTE_MAINTENANCE_INTERVAL=3600

# Runtime network name
_APP_COMPUTE_RUNTIMES_NETWORK=runtimes

# Docker Hub credentials (optional, for private images)
_APP_DOCKER_HUB_USERNAME=
_APP_DOCKER_HUB_PASSWORD=

# Worker processes per core
_APP_WORKER_PER_CORE=6

# ==============================================
# SECURITY OPTIONS
# ==============================================

# Enable abuse protection
_APP_OPTIONS_ABUSE=enabled

# Force HTTPS (disable in Coolify, handled by proxy)
_APP_OPTIONS_FORCE_HTTPS=disabled

# ==============================================
# MONITORING & LOGGING
# ==============================================

# Usage statistics
_APP_USAGE_STATS=enabled

# Logging provider (empty for default)
_APP_LOGGING_PROVIDER=

# Logging configuration
_APP_LOGGING_CONFIG=

# InfluxDB (optional, for metrics)
_APP_INFLUXDB_HOST=
_APP_INFLUXDB_PORT=

# ==============================================
# MAINTENANCE CONFIGURATION
# ==============================================

# Maintenance interval in seconds (default 86400 = 24 hours)
_APP_MAINTENANCE_INTERVAL=86400

# Cache retention in seconds (default 2592000 = 30 days)
_APP_MAINTENANCE_RETENTION_CACHE=2592000

# Execution logs retention (default 1209600 = 14 days)
_APP_MAINTENANCE_RETENTION_EXECUTION=1209600

# Audit logs retention (default 1209600 = 14 days)
_APP_MAINTENANCE_RETENTION_AUDIT=1209600

# Abuse logs retention (default 86400 = 24 hours)
_APP_MAINTENANCE_RETENTION_ABUSE=86400

# Usage hourly retention (default 8640000 = 100 days)
_APP_MAINTENANCE_RETENTION_USAGE_HOURLY=8640000

# ==============================================
# GRAPHQL CONFIGURATION
# ==============================================

_APP_GRAPHQL_MAX_BATCH_SIZE=10
_APP_GRAPHQL_MAX_COMPLEXITY=250
_APP_GRAPHQL_MAX_DEPTH=3

# ==============================================
# VERSION CONTROL (GitHub Integration)
# ==============================================

_APP_VCS_GITHUB_APP_NAME=
_APP_VCS_GITHUB_PRIVATE_KEY=
_APP_VCS_GITHUB_APP_ID=
_APP_VCS_GITHUB_CLIENT_ID=
_APP_VCS_GITHUB_CLIENT_SECRET=
_APP_VCS_GITHUB_WEBHOOK_SECRET=

# ==============================================
# AI ASSISTANT (Optional)
# ==============================================

_APP_ASSISTANT_OPENAI_API_KEY=

# ==============================================
# IMPORTANT NOTES FOR COOLIFY DEPLOYMENT
# ==============================================
# 
# 1. DO NOT create a .env file manually in Coolify
# 2. Configure all variables through Coolify's Environment Variables UI
# 3. Coolify will automatically detect variables from docker-compose.yaml
# 4. REQUIRED variables MUST be set or deployment will fail
# 5. Generate secure random values for all secrets and passwords
# 
# To generate secure random values:
#   openssl rand -base64 32
#   openssl rand -hex 16
# 
# Minimum required variables to start:
#   - _APP_DOMAIN
#   - _APP_OPENSSL_KEY_V1
#   - _APP_EXECUTOR_SECRET
#   - _APP_DB_SCHEMA
#   - _APP_DB_USER
#   - _APP_DB_PASS
#   - _APP_DB_ROOT_PASS
# ==============================================
