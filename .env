# =============================================================
# Appwrite v1.9.5 — Production Environment Variables
# Platform : Coolify (GitHub Docker Compose Deployment)
# Domain   : appwrite.doitfastit.de
#
# INSTRUCTIONS:
#   1. Replace every value marked CHANGE_THIS_* with real secrets.
#   2. Generate secrets with: openssl rand -hex 32
#   3. These values are loaded by Coolify from your .env file.
#      You can also override them in Coolify's Environment UI.
# =============================================================

# =============================================================
# SECTION 1 — General
# =============================================================

# Runtime environment. Must be "production" for live deployments.
_APP_ENV=production

# Default locale code.
_APP_LOCALE=en

# Number of worker threads per CPU core. 6 is a safe default.
_APP_WORKER_PER_CORE=6

# =============================================================
# SECTION 2 — Domain
# =============================================================

# Your Appwrite Console domain. DNS must point to your VPS.
_APP_DOMAIN=appwrite.doitfastit.de

# Usually the same as _APP_DOMAIN for single-domain setups.
_APP_DOMAIN_TARGET=appwrite.doitfastit.de

# Optional: subdomain for cloud functions (leave blank to disable).
_APP_DOMAIN_FUNCTIONS=

# =============================================================
# SECTION 3 — Security (REQUIRED — Change all values below!)
# =============================================================

# Master encryption key. Minimum 32 characters. DO NOT change after first run.
# Generate: openssl rand -hex 32
_APP_OPENSSL_KEY_V1=CHANGE_THIS_32_CHAR_SECRET_KEY_1

# Internal secret shared between Appwrite API and the function executor.
# Generate: openssl rand -hex 32
_APP_EXECUTOR_SECRET=CHANGE_THIS_EXECUTOR_SECRET_32CH

# Internal URL for the function executor proxy (internal Docker service name).
_APP_EXECUTOR_HOST=http://openruntimes-proxy/

# =============================================================
# SECTION 4 — MariaDB Database (REQUIRED — Change passwords!)
# =============================================================

# Database adapter: mariadb (or mariadb for relational workloads)
_APP_DB_ADAPTER=mariadb

# Docker service name — do not change unless you rename the service.
_APP_DB_HOST=mariadb
_APP_DB_PORT=3306

# Database name, user and password.
_APP_DB_SCHEMA=appwrite
_APP_DB_USER=appwrite

# CHANGE THIS: strong password for the appwrite DB user.
_APP_DB_PASS=CHANGE_THIS_STRONG_DB_PASSWORD

# CHANGE THIS: MariaDB root password.
_APP_DB_ROOT_PASS=CHANGE_THIS_STRONG_ROOT_PASSWORD

# =============================================================
# SECTION 5 — Redis Cache & Queue
# =============================================================

# Docker service name — do not change unless you rename the service.
_APP_REDIS_HOST=redis
_APP_REDIS_PORT=6379

# Leave blank if Redis has no authentication.
_APP_REDIS_USER=
_APP_REDIS_PASS=

# =============================================================
# SECTION 6 — SMTP Email (Optional)
# Leave all values blank to disable outgoing email.
# =============================================================

_APP_SMTP_HOST=
_APP_SMTP_PORT=
_APP_SMTP_SECURE=
_APP_SMTP_USERNAME=
_APP_SMTP_PASSWORD=
_APP_SYSTEM_EMAIL_NAME=Appwrite
_APP_SYSTEM_EMAIL_ADDRESS=team@appwrite.io
_APP_SYSTEM_TEAM_EMAIL=

# =============================================================
# SECTION 7 — Storage
# =============================================================

# Per-file upload limit in bytes. Default: 30 MB.
_APP_STORAGE_LIMIT=30000000

# File preview generation limit in bytes. Default: 20 MB.
_APP_STORAGE_PREVIEW_LIMIT=20000000

# ClamAV antivirus. Set to "enabled" only if you run a ClamAV container.
_APP_STORAGE_ANTIVIRUS=disabled
_APP_STORAGE_ANTIVIRUS_HOST=clamav
_APP_STORAGE_ANTIVIRUS_PORT=3310

# Storage backend: local | s3 | dospaces | backblaze | linode | wasabi
_APP_STORAGE_DEVICE=local

# --- AWS S3 (only if _APP_STORAGE_DEVICE=s3) ---
_APP_STORAGE_S3_ACCESS_KEY=
_APP_STORAGE_S3_SECRET=
_APP_STORAGE_S3_REGION=us-east-1
_APP_STORAGE_S3_BUCKET=
_APP_STORAGE_S3_ENDPOINT=

# --- DigitalOcean Spaces (only if _APP_STORAGE_DEVICE=dospaces) ---
_APP_STORAGE_DO_SPACES_ACCESS_KEY=
_APP_STORAGE_DO_SPACES_SECRET=
_APP_STORAGE_DO_SPACES_REGION=
_APP_STORAGE_DO_SPACES_BUCKET=

# --- Backblaze B2 (only if _APP_STORAGE_DEVICE=backblaze) ---
_APP_STORAGE_BACKBLAZE_ACCESS_KEY=
_APP_STORAGE_BACKBLAZE_SECRET=
_APP_STORAGE_BACKBLAZE_REGION=
_APP_STORAGE_BACKBLAZE_BUCKET=

# --- Linode Object Storage (only if _APP_STORAGE_DEVICE=linode) ---
_APP_STORAGE_LINODE_ACCESS_KEY=
_APP_STORAGE_LINODE_SECRET=
_APP_STORAGE_LINODE_REGION=
_APP_STORAGE_LINODE_BUCKET=

# --- Wasabi (only if _APP_STORAGE_DEVICE=wasabi) ---
_APP_STORAGE_WASABI_ACCESS_KEY=
_APP_STORAGE_WASABI_SECRET=
_APP_STORAGE_WASABI_REGION=
_APP_STORAGE_WASABI_BUCKET=

# =============================================================
# SECTION 8 — Functions / Serverless Compute
# =============================================================

# Maximum function bundle size in bytes.
_APP_FUNCTIONS_SIZE_LIMIT=30000000

# Function execution timeout in seconds.
_APP_FUNCTIONS_TIMEOUT=900

# Function build timeout in seconds.
_APP_FUNCTIONS_BUILD_TIMEOUT=900

# CPU limit per function container. 0 = unlimited.
_APP_FUNCTIONS_CPUS=0

# Memory limit per function container (MB). 0 = unlimited.
_APP_FUNCTIONS_MEMORY=0

# Enabled runtimes. Format: runtime-version,runtime-version,...
_APP_FUNCTIONS_RUNTIMES=node-18.0,php-8.0,python-3.9,ruby-3.1

# Time (seconds) before an inactive runtime container is destroyed.
_APP_COMPUTE_INACTIVE_THRESHOLD=600

# How often (seconds) the executor runs maintenance cleanup.
_APP_COMPUTE_MAINTENANCE_INTERVAL=3600

# Docker network name for function runtime containers.
_APP_COMPUTE_RUNTIMES_NETWORK=runtimes

# =============================================================
# SECTION 9 — Usage Statistics
# =============================================================

_APP_USAGE_STATS=enabled

# =============================================================
# SECTION 10 — Maintenance & Retention
# =============================================================

# How often (seconds) the maintenance task runs. Default: 24 hours.
_APP_MAINTENANCE_INTERVAL=86400

# Data retention periods (seconds):
_APP_MAINTENANCE_RETENTION_EXECUTION=1209600
_APP_MAINTENANCE_RETENTION_CACHE=2592000
_APP_MAINTENANCE_RETENTION_ABUSE=86400
_APP_MAINTENANCE_RETENTION_AUDIT=1209600
_APP_MAINTENANCE_RETENTION_USAGE_HOURLY=8640000
_APP_MAINTENANCE_RETENTION_SCHEDULES=86400

# =============================================================
# SECTION 11 — Console Access Control
# =============================================================

# Restrict console registration to the first account only.
_APP_CONSOLE_WHITELIST_ROOT=enabled

# Comma-separated list of allowed email domains (leave blank for all).
_APP_CONSOLE_WHITELIST_EMAILS=

# Comma-separated list of allowed IP addresses (leave blank for all).
_APP_CONSOLE_WHITELIST_IPS=

# =============================================================
# SECTION 12 — Security Options
# =============================================================

# Abuse protection (rate limiting): enabled | disabled
_APP_OPTIONS_ABUSE=enabled

# Router protection (validates host header): enabled | disabled
_APP_OPTIONS_ROUTER_PROTECTION=disabled

# Force HTTPS redirect: enabled | disabled
# Leave disabled — Coolify's proxy handles HTTPS termination.
_APP_OPTIONS_FORCE_HTTPS=disabled

# =============================================================
# SECTION 13 — SMS Messaging (Optional)
# =============================================================

# SMS provider string. Example: vonage://KEY:SECRET@default/
_APP_SMS_PROVIDER=

# SMS sender number or name.
_APP_SMS_FROM=

# =============================================================
# SECTION 14 — GraphQL
# =============================================================

_APP_GRAPHQL_MAX_BATCH_SIZE=10
_APP_GRAPHQL_MAX_COMPLEXITY=250
_APP_GRAPHQL_MAX_DEPTH=3

# =============================================================
# SECTION 15 — GitHub VCS Integration (Optional)
# =============================================================

_APP_VCS_GITHUB_APP_NAME=
_APP_VCS_GITHUB_PRIVATE_KEY=
_APP_VCS_GITHUB_APP_ID=
_APP_VCS_GITHUB_CLIENT_ID=
_APP_VCS_GITHUB_CLIENT_SECRET=
_APP_VCS_GITHUB_WEBHOOK_SECRET=

# =============================================================
# SECTION 16 — Appwrite AI Assistant (Optional)
# =============================================================

# OpenAI API key for the built-in AI assistant feature.
_APP_ASSISTANT_OPENAI_API_KEY=

# =============================================================
# SECTION 17 — Error Logging (Optional)
# =============================================================

# Logging provider: sentry | raygun | appsignal | logowl (leave blank to disable)
_APP_LOGGING_PROVIDER=

# Provider-specific configuration string.
_APP_LOGGING_CONFIG=

# =============================================================
# SECTION 18 — Docker Hub (Optional)
# Set credentials to avoid Docker Hub pull rate limits.
# =============================================================

_APP_DOCKER_HUB_USERNAME=
_APP_DOCKER_HUB_PASSWORD=

# =============================================================
# SECTION 19 — OpenRuntimes Executor Pull Policy
# =============================================================

# Whether executor should auto-pull runtime images: enabled | disabled
OPR_EXECUTOR_IMAGE_PULL=enabled
