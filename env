# -------------------------------------------------------
# Appwrite Self-Hosted — Environment Variables
# Edit the values marked with <CHANGE_THIS> before running
# -------------------------------------------------------

# General
_APP_ENV=production
_APP_LOCALE=en
_APP_WORKER_PER_CORE=6

# Domain — for local PC use "localhost"
_APP_DOMAIN=localhost
_APP_CONSOLE_DOMAIN=localhost
_APP_DOMAIN_TARGET_A=127.0.0.1
_APP_DOMAIN_TARGET_CNAME=localhost
_APP_DOMAIN_FUNCTIONS=functions.localhost

# Security — CHANGE THIS to a random 32-character string
# Generate one at: https://1password.com/password-generator/
_APP_OPENSSL_KEY_V1=your-secret-key-change-this-32ch

# Executor secret — CHANGE THIS (used internally between services)
_APP_EXECUTOR_SECRET=your-executor-secret-change-this
_APP_EXECUTOR_HOST=http://openruntimes-proxy/

# Database - MariaDB adapter (1.9.x default is MongoDB)
_APP_DB_ADAPTER=mariadb
_APP_DB_HOST=mariadb
_APP_DB_PORT=3306
_APP_DB_SCHEMA=appwrite
_APP_DB_USER=appwrite
_APP_DB_PASS=appwrite_db_password
_APP_DB_ROOT_PASS=rootsecretpassword

# Redis
_APP_REDIS_HOST=redis
_APP_REDIS_PORT=6379
_APP_REDIS_USER=
_APP_REDIS_PASS=

# SMTP (optional — leave blank to disable emails)
_APP_SMTP_HOST=
_APP_SMTP_PORT=
_APP_SMTP_SECURE=
_APP_SMTP_USERNAME=
_APP_SMTP_PASSWORD=
_APP_SYSTEM_EMAIL_NAME=Appwrite
_APP_SYSTEM_EMAIL_ADDRESS=team@appwrite.io
_APP_SYSTEM_TEAM_EMAIL=

# Storage
_APP_STORAGE_LIMIT=30000000          # 30 MB per file
_APP_STORAGE_PREVIEW_LIMIT=20000000  # 20 MB
_APP_STORAGE_ANTIVIRUS=disabled
_APP_STORAGE_ANTIVIRUS_HOST=clamav
_APP_STORAGE_ANTIVIRUS_PORT=3310
_APP_STORAGE_DEVICE=local            # local | s3 | dospaces | backblaze | linode | wasabi

# S3-compatible storage (only needed if _APP_STORAGE_DEVICE != local)
_APP_STORAGE_S3_ACCESS_KEY=
_APP_STORAGE_S3_SECRET=
_APP_STORAGE_S3_REGION=us-east-1
_APP_STORAGE_S3_BUCKET=
_APP_STORAGE_S3_ENDPOINT=

# Usage stats
_APP_USAGE_STATS=enabled

# Functions / Compute
_APP_FUNCTIONS_TIMEOUT=900
_APP_COMPUTE_BUILD_TIMEOUT=900
_APP_COMPUTE_CPUS=0
_APP_COMPUTE_MEMORY=0
_APP_COMPUTE_SIZE_LIMIT=0
_APP_COMPUTE_INACTIVE_THRESHOLD=600
_APP_COMPUTE_MAINTENANCE_INTERVAL=3600
_APP_COMPUTE_RUNTIMES_NETWORK=runtimes
_APP_FUNCTIONS_RUNTIMES=node-18.0,php-8.0,python-3.9,ruby-3.1

# Maintenance
_APP_MAINTENANCE_INTERVAL=86400
_APP_MAINTENANCE_RETENTION_EXECUTION=1209600
_APP_MAINTENANCE_RETENTION_CACHE=2592000
_APP_MAINTENANCE_RETENTION_ABUSE=86400
_APP_MAINTENANCE_RETENTION_AUDIT=1209600
_APP_MAINTENANCE_RETENTION_USAGE_HOURLY=8640000
_APP_MAINTENANCE_RETENTION_SCHEDULES=86400

# Options
_APP_OPTIONS_ABUSE=enabled
_APP_OPTIONS_ROUTER_PROTECTION=disabled
_APP_OPTIONS_FORCE_HTTPS=disabled

# Console access (leave empty to allow all)
_APP_CONSOLE_WHITELIST_ROOT=enabled
_APP_CONSOLE_WHITELIST_EMAILS=
_APP_CONSOLE_WHITELIST_IPS=

# Logging (optional)
_APP_LOGGING_CONFIG=

# Docker Hub (optional — avoids pull rate limits)
_APP_DOCKER_HUB_USERNAME=
_APP_DOCKER_HUB_PASSWORD=

# GraphQL limits
_APP_GRAPHQL_MAX_BATCH_SIZE=10
_APP_GRAPHQL_MAX_COMPLEXITY=250
_APP_GRAPHQL_MAX_DEPTH=3

# SMS (optional)
_APP_SMS_PROVIDER=
_APP_SMS_FROM=

# Assistant AI (optional)
_APP_ASSISTANT_OPENAI_API_KEY=

# Database shared tables
_APP_DATABASE_SHARED_TABLES=